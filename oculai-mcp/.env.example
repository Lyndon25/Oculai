# ============================================================
# Oculai MCP Server — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# The .env file is read by pydantic-settings with mtime-aware caching.

# ---- PostgreSQL (required) ---------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=oculai
DB_USER=oculai
DB_PASSWORD=oculai_dev
DB_POOL_MIN=1
DB_POOL_MAX=10

# ---- Academic APIs (optional — enable corresponding sources) ----
SEMANTIC_SCHOLAR_API_KEY=
OPENALEX_EMAIL=
GITHUB_TOKEN=

# ---- Chinese Search (optional — enables Baidu sources) ------
BAIDU_API_KEY=

# ---- Web Search (optional — enables web search tool) --------
TAVILY_API_KEY=
EXA_API_KEY=
