# ============================================================
# Oculai MCP Server — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# The .env file is read by pydantic-settings with mtime-aware caching.
#
# Quick start: only PostgreSQL is required. All API keys are optional
# but strongly recommended for production-quality sourcing results.

# ---- PostgreSQL (required) ---------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=oculai
DB_USER=oculai
DB_PASSWORD=oculai_dev
DB_POOL_MIN=1
DB_POOL_MAX=10

# ---- Academic APIs (optional — enable corresponding sources) ----
#
# Semantic Scholar API Key
#   Source: semantic_scholar
#   Without key: 100 requests per 5 minutes
#   With key:    higher rate limits (undocumented, but significant)
#   Get free key: https://api.semanticscholar.org/api-docs/#tag/API-Key
#   (Click "Request API Key" on the right panel)
SEMANTIC_SCHOLAR_API_KEY=

#
# OpenAlex Email
#   Source: openalex
#   Without email: standard rate limits
#   With email:    placed in "polite pool" with better rate limits
#   Usage: any valid email address — no registration needed
#   Docs: https://docs.openalex.org/api-1/overview#rate-limits
OPENALEX_EMAIL=

#
# GitHub Personal Access Token
#   Source: github, industry
#   Without token: 60 requests/hour (effectively unusable for serious sourcing)
#   With token:    5000 requests/hour
#   Create: https://github.com/settings/tokens
#   Choose: "Generate new token (classic)" — no scopes needed for public repos
GITHUB_TOKEN=

# ---- Chinese Search -----------------------------------------
#
# Baidu Qianfan (千帆) API Key
#   Sources: baidu_qianfan (web search), baidu_scholar (academic search)
#   Free: 100 calls/day for web search. Scholar search also available.
#   Get key: https://console.bce.baidu.com/qianfan/ais/console/applicationConsole/application
#   Format: bce-v3/ALTAK-xxx/xxx (full Bearer token)
BAIDU_API_KEY=

# ---- Web Search (optional — enables web search tool) --------
#
# Tavily Search API Key
#   Source: web_search (provider=tavily)
#   Free tier: 1000 API calls/month (no credit card required)
#   Usage: 1 credit per basic search, 2 credits per advanced search
#   Sign up: https://tavily.com
TAVILY_API_KEY=

#
# Exa Search API Key
#   Source: web_search (provider=exa)
#   Free tier: 2000 one-time credits
#   Usage: neural search with content extraction
#   Sign up: https://exa.ai
EXA_API_KEY=
