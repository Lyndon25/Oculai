# Oculai Database — Environment Variables
# Copy to .env and fill in values

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=oculai
DB_USER=oculai
DB_PASSWORD=oculai_dev
DB_POOL_MIN=5
DB_POOL_MAX=50

# pgvector
VECTOR_DIMENSIONS=1536

# Backup
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=7
BACKUP_WEEKLY_RETENTION=4
BACKUP_MONTHLY_RETENTION=12

# WAL Archive
WAL_ARCHIVE_DIR=./wal_archive

# Monitoring
METRICS_EXPORT_INTERVAL_SECONDS=60
