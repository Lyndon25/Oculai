{
  "name": "oculai-desktop",
  "version": "0.0.1",
  "description": "Oculai Talent Sourcing Desktop - Multi-Agent Talent Sourcing System",
  "main": "dist/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n vite,electron \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "npm run generate-tools && tsc -p tsconfig.main.json && vite build && electron-builder",
    "start": "electron .",
    "typecheck": "tsc --noEmit",
    "generate-tools": "python ../scripts/generate_pi_tools.py"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.78.1",
    "@earendil-works/pi-coding-agent": "^0.78.1",
    "electron-store": "^10.0.0",
    "lucide-react": "^0.400.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "recharts": "^2.12.0",
    "tailwindcss": "^3.4.6",
    "typebox": "^0.32.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^31.3.0",
    "electron-builder": "^24.13.0",
    "postcss": "^8.4.39",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "wait-on": "^7.2.0"
  }
}
